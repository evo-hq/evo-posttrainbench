executable = /bin/bash
judge_mode = --gpt-only
arguments = src/disallowed_usage_judge/rerun_judge/rerun_single_gpt_only.sh $(result_dir) $(judge_mode)
environment = "HOME=$ENV(HOME)"
error = test_$(Cluster).err
output = test_$(Cluster).out
log = test_$(Cluster).log
concurrency_limits=user.judge:1250
request_memory = 81920
request_cpus = 8
request_disk=100G
+BypassLXCfs="true"
queue
